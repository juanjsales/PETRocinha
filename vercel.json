{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://*.circle.so https://circle.so;"
        },
        {
          "key": "X-Frame-Options",
          "value": "ALLOW-FROM https://circle.so"
        }
      ]
    }
  ]
}